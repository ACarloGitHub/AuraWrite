  "cards": {
    "found-1": {
      "created": 1741820400000,
      "modified": 1741820400000,
      "note": "SCELTA CRITICA:\n\nLibreOffice plugin:\n+ Già abbiamo UNO socket\n+ Base matura, formattazione pronta\n+ Export già funzionante\n- Limitato da LibreOffice\n- UX meno moderna\n\nTauri app:\n+ UX moderna, flex\n+ Controllo totale\n- Ricostruire editor da zero (ENORME)\n- Formattazione complessa da zero\n\nObsidian plugin:\n+ Già esistono MD, plugin\n- Meno controllo\n- Non è word processor\n\nRACCOMANDAZIONE: LibreOffice per MVP veloce, Tauri per v2"
    },
    "ed-3": {
      "created": 1741820400000,
      "modified": 1741820400000,
      "note": "DIFFERENTIATOR CHIAVE:\n\nIl 'nastro adesivo' è l'idea forte.\nL'utente vede:\n- Testo originale (sfondo bianco)\n- Suggerimento AI sovrapposto (sfondo colorato)\n- Pulsante per switchare tra i due\n- Approva = sostituisce\n- Rifiuta = rimuove suggerimento"
    },
    "tr-6": {
      "created": 1741820400000,
      "modified": 1741820400000,
      "note": "Preso da Novelist:\n\nCerchio colore stato:\n- 🟡 Giallo = Bozza\n- 🟢 Verde = Completato\n- Rosso = Da rivedere"
    },
    "an-1": {
      "created": 1741820400000,
      "modified": 1741820400000,
      "note": "Ritmo = velocità della narrazione.\n\nL'AI analizza:\n- Lunghezza frasi\n- Dialoghi vs narrazione\n- Azione vs riflessione\n- Cliffhanger a fine capitolo"
    },
    "tech-4": {
      "created": 1741820400000,
      "modified": 1741820400000,
      "note": "ARCHITETTURA AI:\n\nLocale (Ollama):\n- Privacy totale\n- Funziona offline\n- Modelli più piccoli\n\nAPI (OpenAI/Anthropic):\n- Modelli potenti\n- Costo per chiamata\n- Dipendenza esterna\n\nOpenClaw:\n- Infrastruttura pronta\n- Può usare modelli vari\n- Richiede server\n\nIBRIDO:\n- L'utente sceglie nelle impostazioni\n- 'Voglio privacy' → Locale\n- 'Voglio potenza' → API con sua key"
    },
